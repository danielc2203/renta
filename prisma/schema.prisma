generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  name             String
  role             String   @default("ACCOUNTANT") // ACCOUNTANT, SUPERADMIN
  isActive         Boolean  @default(true)
  alertDaysRed     Int      @default(7)
  alertDaysYellow  Int      @default(15)
  whatsappTemplate String?
  dianCalendarRules String?
  magicLinkExpDays Int      @default(10)
  clients          Client[]
}

model Client {
  id              String      @id @default(uuid())
  adminId         String?     // Nullable at first for migration, will become required later
  admin           Admin?      @relation(fields: [adminId], references: [id])
  documentNumber  String      @unique
  name            String
  phone           String?
  dueDate         DateTime
  status          String      @default("Pendiente") // Pendiente, En Proceso, Completado
  dianPassword    String?
  magicLinkToken  String?     @unique
  magicLinkExp    DateTime?
  documents       Document[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  fee             Int?
  paymentStatus   String      @default("Debe") // Debe, Pagado
}

model SystemSettings {
  id               Int      @id @default(1)
  appName          String   @default("Renta Colombia")
  logoUrl          String?
  allowNewSignups  Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}

model Document {
  id         String   @id @default(uuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])
  type       String
  filePath   String
  fileName   String
  uploadedAt DateTime @default(now())
}
